# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Copiez ce fichier en .env et remplissez vos valeurs.
# Ne commitez JAMAIS le fichier .env dans Git.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Anthropic (Claude) ────────────────────────────────────────────────────
# Obtenez votre clé sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle Claude à utiliser (claude-sonnet-4-6 recommandé, claude-opus-4-8 pour plus de précision)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Chemin vers le fichier credentials.json téléchargé depuis Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json

# Chemin où sera sauvegardé le token OAuth (créé automatiquement au premier lancement)
GMAIL_TOKEN_PATH=token.json

# ── Recherche Gmail ───────────────────────────────────────────────────────────
# Requête Gmail par défaut (syntaxe Gmail standard)
# Exemples :
#   has:attachment is:unread newer_than:7d
#   has:attachment is:unread newer_than:30d from:fournisseur@exemple.fr
GMAIL_SEARCH_QUERY=has:attachment is:unread newer_than:7d

# Taille maximale des pièces jointes à traiter (en mégaoctets)
GMAIL_MAX_ATTACHMENT_MB=10

# Nom du label Gmail appliqué aux mails traités
GMAIL_LABEL_TRAITE=precompta-traite

# ── Expert-comptable ──────────────────────────────────────────────────────────
# Adresse email à qui seront adressés les brouillons
EXPERT_COMPTABLE_EMAIL=votre.expert@cabinet-comptable.fr

# ── Stockage local ────────────────────────────────────────────────────────────
# Dossier temporaire pour les pièces jointes (supprimé après traitement par défaut)
PIECES_TEMP_DIR=pieces_temp
